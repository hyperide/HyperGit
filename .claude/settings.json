{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "PYTHONPATH=/Users/ultra/xp/agent-tools/lib python3 -m cc_hook_bridge PreToolUse"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "PYTHONPATH=/Users/ultra/xp/agent-tools/lib python3 -m cc_hook_bridge PreToolUse"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PYTHONPATH=/Users/ultra/xp/agent-tools/lib python3 -m cc_hook_bridge Stop"
          }
        ]
      }
    ]
  }
}
